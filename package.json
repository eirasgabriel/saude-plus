{
  "name": "saude-plus",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo do Saude+ com frontend React e backend Node",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node scripts/start-dev.js",
    "frontend": "npm --workspace saude-plus-frontend run iniciar",
    "frontend:build": "npm --workspace saude-plus-frontend run compilar",
    "frontend:test": "npm --workspace saude-plus-frontend run testar --",
    "backend": "npm --workspace saude-plus-backend run start",
    "backend:check": "npm --workspace saude-plus-backend run check",
    "backend:test": "npm --workspace saude-plus-backend run test",
    "lint": "node ./node_modules/eslint/bin/eslint.js --resolve-plugins-relative-to frontend backend/src frontend/src scripts --ext .js,.jsx",
    "format:check": "node scripts/check-format.js",
    "iniciar": "node scripts/start-dev.js",
    "compilar": "npm run frontend:build",
    "testar": "npm run backend:test && npm run frontend:test -- --watchAll=false --runInBand",
    "vercel:function:check": "node scripts/check-vercel-function.js",
    "deploy:check": "npm run backend:check && npm run backend:test && npm run frontend:test -- --watchAll=false --runInBand && npm run frontend:build && npm run lint && npm run vercel:function:check && npm run format:check"
  },
  "engines": {
    "node": ">=18"
  }
}
