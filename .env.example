NODE_ENV=development
PORT=3333
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TOKEN_TTL_SEGUNDOS=28800
REQUEST_BODY_LIMIT_BYTES=10485760
RELATORIOS_DEBUG=false
JWT_SECRET=substitua-por-um-segredo-local-com-32-caracteres-ou-mais
RECOVERY_SECRET=defina-um-codigo-temporario-apenas-para-desenvolvimento
AUTH_COOKIE_ENABLED=false
REPOSITORY_DRIVER=memory
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saude_plus
DB_USER=saude_plus_app
DB_PASSWORD=substitua-por-senha-local
DB_SSL=false

REACT_APP_BACKEND_URL=http://localhost:3333
# Google Maps Platform
# Voce pode usar a mesma chave nas 3 variaveis se ela estiver autorizada para
# Maps Embed API, Geocoding API e Maps JavaScript API.
REACT_APP_GOOGLE_MAPS_EMBED_API_KEY=
REACT_APP_GOOGLE_MAPS_GEOCODING_API_KEY=
REACT_APP_GOOGLE_MAPS_JAVASCRIPT_API_KEY=
# Compatibilidade antiga: usado como fallback se as chaves acima estiverem vazias.
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@saude-plus.local
